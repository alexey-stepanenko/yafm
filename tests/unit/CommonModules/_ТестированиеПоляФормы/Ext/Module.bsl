Процедура ИсполняемыеСценарии() Экспорт 
	МФТестированиеКлиентСерверПовтИсп
		.ФреймворкТестирования()
		.ЮТТесты
		.ДобавитьТестовыйНабор("Тестирование поля формы")
			.ДобавитьТест("ПолеФормыПолеHTMLДокумента", "Тестирование элемента ПолеФормы вида ""ПолеHTMLДокумента""")
			.ДобавитьТест("ПолеФормыПолеPDFДокумента", "Тестирование элемента ПолеФормы вида ""ПолеPDFДокумента""")
			.ДобавитьТест("ПолеФормыПолеВвода", "Тестирование элемента ПолеФормы вида ""ПолеВвода""")
			.ДобавитьТест("ПолеФормыПолеГеографическойСхемы", "Тестирование элемента ПолеФормы вида ""ПолеГеографическойСхемы""")
			.ДобавитьТест("ПолеФормыПолеГрафическойСхемы", "Тестирование элемента ПолеФормы вида ""ПолеГрафическойСхемы""")
			.ДобавитьТест("ПолеФормыПолеДендрограммы", "Тестирование элемента ПолеФормы вида ""ПолеДендрограммы""")
			.ДобавитьТест("ПолеФормыПолеДиаграммы", "Тестирование элемента ПолеФормы вида ""ПолеДиаграммы""")
			.ДобавитьТест("ПолеФормыПолеДиаграммыГанта", "Тестирование элемента ПолеФормы вида ""ПолеДиаграммыГанта""")
			.ДобавитьТест("ПолеФормыПолеИндикатора", "Тестирование элемента ПолеФормы вида ""ПолеИндикатора""")
			.ДобавитьТест("ПолеФормыПолеКалендаря", "Тестирование элемента ПолеФормы вида ""ПолеКалендаря""")
			.ДобавитьТест("ПолеФормыПолеКартинки", "Тестирование элемента ПолеФормы вида ""ПолеКартинки""")
			.ДобавитьТест("ПолеФормыПолеНадписи", "Тестирование элемента ПолеФормы вида ""ПолеНадписи""")
			.ДобавитьТест("ПолеФормыПолеПереключателя", "Тестирование элемента ПолеФормы вида ""ПолеПереключателя""")
			.ДобавитьТест("ПолеФормыПолеПериода", "Тестирование элемента ПолеФормы вида ""ПолеПериода""")
			.ДобавитьТест("ПолеФормыПолеПланировщика", "Тестирование элемента ПолеФормы вида ""ПолеПланировщика""")
			.ДобавитьТест("ПолеФормыПолеПолосыРегулирования", "Тестирование элемента ПолеФормы вида ""ПолеПолосыРегулирования""")
			.ДобавитьТест("ПолеФормыПолеТабличногоДокумента", "Тестирование элемента ПолеФормы вида ""ПолеТабличногоДокумента""")
			.ДобавитьТест("ПолеФормыПолеТекстовогоДокумента", "Тестирование элемента ПолеФормы вида ""ПолеТекстовогоДокумента""")
			.ДобавитьТест("ПолеФормыПолеФлажка", "Тестирование элемента ПолеФормы вида ""ПолеФлажка""")
			.ДобавитьТест("ПолеФормыПолеФорматированногоДокумента", "Тестирование элемента ПолеФормы вида ""ПолеФорматированногоДокумента""")
	;
КонецПроцедуры

