#Область СлужебныйПрограммныйИнтерфейс

Функция Зависимость(ИмяПоля, ПредставлениеЗначения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("ИмяПоля", ИмяПоля);
	Результат.Вставить("ПредставлениеЗначения", ПредставлениеЗначения);
	
	Возврат Результат;
КонецФункции

Процедура ПротестироватьСвойстваЭлементаФормы(ИмяТестируемойФормы, ИмяТестируемогоРеквизита, Зависимость) Экспорт
	// Дано
	
	_ЮТест = МФТестированиеКлиентСерверПовтИсп.ФреймворкТестирования().ЮТест;
	СинонимыСвойствЭлементов = ТестированиеСлужебныйВызовСервера.СинонимыСвойствЭлементов();
	Попытка
		ПараметрыТестируемойФормы = Новый Структура;
		ТестируемаяФорма = ПолучитьФорму(ИмяТестируемойФормы, ПараметрыТестируемойФормы);
	Исключение
		ТекстИсключения = СтрШаблон(
			НСтр("ru='Не найдена форма ""%1""'"),
			ИмяТестируемойФормы
		);
		
		ВызватьИсключение ТекстИсключения;
	КонецПопытки;
	ТестируемыйРеквизит = ТестируемаяФорма.Элементы.Найти(ИмяТестируемогоРеквизита);
	Если ТестируемыйРеквизит = Неопределено Тогда
		ТекстИсключения = СтрШаблон(
			НСтр("ru='На форме ""%1"" не найден реквизит ""%2""'"),
			ИмяТестируемойФормы,
			ИмяТестируемогоРеквизита
		);
		
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	// Когда
	
	ТипЭлементаФормы = ТипЗнч(ТестируемыйРеквизит);
	ОписанияСвойств = ТестированиеСлужебныйВызовСервера.ОписанияСвойствЭлементаФормы(ТипЭлементаФормы, Зависимость);
	СуществующиеСвойства = Новый Соответствие;
	Для Каждого СвойствоЭлемента Из СинонимыСвойствЭлементов Цикл
		Синонимы = СтрРазделить(СвойствоЭлемента.Значение, ",");
		ИдентификаторСвойства = ВРег(Синонимы[0]);
		Если ОписанияСвойств.СвойстваНедоступныеНаКлиенте.Найти(ИдентификаторСвойства) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Попытка
			ЗначениеСвойства = ТестируемыйРеквизит[ИдентификаторСвойства];
			СуществующиеСвойства.Вставить(ИдентификаторСвойства, ТипЗнч(ЗначениеСвойства));
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
	СуществующиеСвойстваДляПроверки = ОтсортированныйМассивИзКоллекции(СуществующиеСвойства);
	ОпределенныеСвойстваДляПроверки = ОтсортированныйМассивИзКоллекции(ОписанияСвойств.СвойстваЭлемента);
	
	// Тогда
	
	_ЮТест.ОжидаетЧто(СуществующиеСвойстваДляПроверки)
		.Равно(ОпределенныеСвойстваДляПроверки)
	;
КонецПроцедуры

Процедура ПротестироватьСобытияЭлементаФормы(ИмяТестируемойФормы, ИмяТестируемогоРеквизита, Зависимость) Экспорт
	// Дано
	
	_ЮТест = МФТестированиеКлиентСерверПовтИсп.ФреймворкТестирования().ЮТест;
	СинонимыСвойствЭлементов = ТестированиеСлужебныйВызовСервера.СинонимыСвойствЭлементов();
	Попытка
		ПараметрыТестируемойФормы = Новый Структура;
		ПараметрыТестируемойФормы.Вставить("ИмяТестируемогоРеквизита", ИмяТестируемогоРеквизита);
		ТестируемаяФорма = ПолучитьФорму(ИмяТестируемойФормы, ПараметрыТестируемойФормы);
	Исключение
		ТекстИсключения = СтрШаблон(
			НСтр("ru='Не найдена форма ""%1""'"),
			ИмяТестируемойФормы
		);
		
		ВызватьИсключение ТекстИсключения;
	КонецПопытки;
	ТестируемыйРеквизит = ТестируемаяФорма.Элементы.Найти(ИмяТестируемогоРеквизита);
	Если ТестируемыйРеквизит = Неопределено Тогда
		ТекстИсключения = СтрШаблон(
			НСтр("ru='На форме ""%1"" не найден реквизит ""%2""'"),
			ИмяТестируемойФормы,
			ИмяТестируемогоРеквизита
		);
		
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	// Когда
	
	ТипЭлементаФормы = ТипЗнч(ТестируемыйРеквизит);
	ОписанияСвойств = ТестированиеСлужебныйВызовСервера.ОписанияСвойствЭлементаФормы(ТипЭлементаФормы, Зависимость);
	СобытияТестируемогоЭлемента = ТестируемаяФорма.СобытияТестируемогоЭлемента();
	СуществующиеСобытия = Новый Соответствие;
	Для Каждого Элемент Из СтрРазделить(СобытияТестируемогоЭлемента, ";") Цикл
		СуществующиеСобытия.Вставить(Элемент, Тип("Строка"));
	КонецЦикла;
	
	СуществующиеСобытияДляПроверки = ОтсортированныйМассивИзКоллекции(СуществующиеСобытия);
	ОпределенныеСобытияДляПроверки = ОтсортированныйМассивИзКоллекции(ОписанияСвойств.СобытияЭлемента);
	
	// Тогда
	
	_ЮТест.ОжидаетЧто(СуществующиеСобытияДляПроверки)
		.Равно(ОпределенныеСобытияДляПроверки)
	;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОтсортированныйМассивИзКоллекции(Коллекция)
	Результат = Новый Массив;
	
	СписокЗначений = Новый СписокЗначений;
	Для Каждого ЭлементКоллекции Из Коллекция Цикл
		СписокЗначений.Добавить(ЭлементКоллекции.Ключ, ЭлементКоллекции.Ключ);
	КонецЦикла;
	СписокЗначений.СортироватьПоЗначению(НаправлениеСортировки.Возр);
	
	Для Каждого ЭлементСписка Из СписокЗначений Цикл
		Результат.Добавить(Новый Структура(
			"ИмяСвойства, ТипСвойства",
			ЭлементСписка.Значение,
			Коллекция.Получить(ЭлементСписка.Значение)
		));
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

#КонецОбласти
